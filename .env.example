# ---------------------------------------------------------------------------
# Market Scenario and Stress Testing Workbench — environment template
#
# Copy this file to `.env` and adjust values as needed:
#     cp .env.example .env
#
# docker-compose reads `./.env` for every service (postgres, redis, backend,
# worker, frontend). The backend also loads these via app/core/config.py.
# Never commit your real `.env` — it is gitignored.
# ---------------------------------------------------------------------------

# --- Application ---
APP_ENV=development
APP_NAME="Market Scenario and Stress Testing Workbench"
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:3000

# --- Postgres (consumed by the postgres service in docker-compose) ---
POSTGRES_DB=stress_workbench
POSTGRES_USER=stress_user
POSTGRES_PASSWORD=stress_password

# --- Database (backend) ---
# Must stay consistent with the POSTGRES_* values above. The hostname is the
# docker-compose service name (`postgres`); use `localhost` when running the
# backend outside Docker.
DATABASE_URL=postgresql+psycopg://stress_user:stress_password@postgres:5432/stress_workbench

# --- Redis / Celery ---
# Hostname is the docker-compose service name (`redis`); use `localhost`
# when running outside Docker.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Market data provider ---
# One of: yfinance | polygon | alpaca
DATA_PROVIDER=yfinance
# Directory (inside the backend container) where parquet caches are written.
DATA_CACHE_DIR=data/cache
# Cached data older than this many hours is treated as stale.
DATA_STALE_AFTER_HOURS=24
YFINANCE_TIMEOUT_SECONDS=30

# Polygon.io — required only when DATA_PROVIDER=polygon
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# Alpaca — required only when DATA_PROVIDER=alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://data.alpaca.markets

# FRED (macro data) — optional; improves macro fetch reliability/limits
FRED_API_KEY=
FRED_BASE_URL=https://fred.stlouisfed.org

# --- Frontend ---
# Base URL the Next.js app uses to reach the backend API (used in later
# frontend modules). Use http://localhost:8000 for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8000
